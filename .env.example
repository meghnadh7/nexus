# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ─── LangSmith ────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=nexus-production
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── Pinecone ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=nexus-codebase

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_ORG=your-org
GITHUB_REPO=your-repo

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_DEFAULT_CHANNEL=#devops-alerts

# ─── Jira ─────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=...
JIRA_PROJECT_KEY=ENG

# ─── Datadog ──────────────────────────────────────────────────────────────────
DATADOG_API_KEY=...
DATADOG_APP_KEY=...

# ─── Databases ────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://nexus:password@postgres:5432/nexus
REDIS_URL=redis://redis:6379/0

# ─── MCP Server URLs ──────────────────────────────────────────────────────────
MCP_GITHUB_URL=http://mcp-github:8001
MCP_SLACK_URL=http://mcp-slack:8002
MCP_JIRA_URL=http://mcp-jira:8003
MCP_DATADOG_URL=http://mcp-datadog:8004

# ─── Agent Behaviour ──────────────────────────────────────────────────────────
HUMAN_IN_THE_LOOP=false
MAX_AGENT_ITERATIONS=10

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=production
